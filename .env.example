# Copy to .env on the deployment host and fill in HF_TOKEN.
# This repository intentionally does not download model weights locally.

# Hugging Face token with access to mistralai/Mistral-Medium-3.5-128B.
HF_TOKEN=hf_your_token_here

# Nightly ROCm vLLM image. Keep this on nightly unless you intentionally pin a digest.
VLLM_IMAGE=vllm/vllm-openai-rocm:nightly

# Model and OpenAI-compatible served name.
MODEL_ID=mistralai/Mistral-Medium-3.5-128B
SERVED_MODEL_NAME=mistral-medium-3.5-128b

# Default assumes an 8x MI300X node. The official model card uses TP=8.
TENSOR_PARALLEL_SIZE=8
ROCR_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
HIP_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# 256k context. Lower this if you need higher throughput or hit KV-cache limits.
MAX_MODEL_LEN=262144
GPU_MEMORY_UTILIZATION=0.80
MAX_NUM_BATCHED_TOKENS=16384
MAX_NUM_SEQS=128

# Host port for the OpenAI-compatible API.
VLLM_PORT=8000

# Docker named volume by default. Set to an absolute path on the deployment host
# if you want the Hugging Face/vLLM cache on a specific mount, for example:
# MODEL_CACHE_DIR=/mnt/models/huggingface
MODEL_CACHE_DIR=hf-cache
