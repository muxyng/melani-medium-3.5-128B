# Copy to .env on the deployment host and fill in HF_TOKEN.
# This repository intentionally does not download model weights locally.

# Hugging Face token with access to mistralai/Mistral-Medium-3.5-128B.
HF_TOKEN=hf_your_token_here

# Nightly ROCm vLLM image. Keep this on nightly unless you intentionally pin a digest.
VLLM_IMAGE=vllm/vllm-openai-rocm:nightly

# Nightly AMD MAX image. Current nightly tag observed on 2026-05-03:
# modular/max-amd:26.4.0.dev2026050306
MAX_IMAGE=modular/max-amd:nightly

# ROCm SGLang image. Current generic MI300X ROCm daily tag observed on 2026-05-03:
# rocm/sgl-dev:v0.5.10.post1-rocm720-mi30x-20260502
SGLANG_IMAGE=rocm/sgl-dev:v0.5.10.post1-rocm720-mi30x-20260502

# Model and OpenAI-compatible served name.
MODEL_ID=mistralai/Mistral-Medium-3.5-128B
SERVED_MODEL_NAME=mistral-medium-3.5-128b

# Default targets the currently provisioned 1x MI300X VM.
# Increase these together for multi-GPU deployments.
TENSOR_PARALLEL_SIZE=1
ROCR_VISIBLE_DEVICES=0
HIP_VISIBLE_DEVICES=0

# 32k context for the planned VM deployment. The official model supports 256k.
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.80
MAX_NUM_BATCHED_TOKENS=8192
MAX_NUM_SEQS=4

# Host port for the OpenAI-compatible API.
VLLM_PORT=8000
MAX_PORT=8001
SGLANG_PORT=8002

# Bearer token required by the vLLM OpenAI-compatible API.
VLLM_API_KEY=change_me_to_a_random_secret

# Docker named volume by default. Set to an absolute path on the deployment host
# if you want the Hugging Face/vLLM cache on a specific mount, for example:
# MODEL_CACHE_DIR=/mnt/models/huggingface
MODEL_CACHE_DIR=hf-cache
MAX_CACHE_DIR=max-cache
SGLANG_CACHE_DIR=sglang-cache
